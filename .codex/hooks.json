{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/format-rust.sh\"",
            "timeout": 30,
            "statusMessage": "Formatting changed Rust files..."
          }
        ]
      }
    ]
  }
}
